{
  "name": "gg-mcp-server",
  "version": "1.0.0",
  "description": "MCP server + web app for Garmin Golf driving range data analysis",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/server.js",
    "start:stdio": "node dist/server.js",
    "start:web": "node dist/server.js --sse",
    "console": "node dist/console/index.js",
    "inspect": "npx -y @modelcontextprotocol/inspector node dist/server.js",
    "dev": "tsc && node dist/server.js --sse"
  },
  "keywords": ["mcp", "garmin", "golf", "driving-range"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "multer": "^2.0.1",
    "ollama": "^0.6.3",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
